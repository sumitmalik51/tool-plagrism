{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.37.4.10188",
      "templateHash": "1843479787314240012"
    }
  },
  "parameters": {
    "appName": {
      "type": "string",
      "defaultValue": "plagiarismguard",
      "metadata": {
        "description": "Base name used for all resources"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "skuName": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",
        "B2",
        "B3",
        "S1",
        "S2",
        "S3",
        "P1v3",
        "P2v3"
      ],
      "metadata": {
        "description": "App Service Plan SKU"
      }
    },
    "pythonVersion": {
      "type": "string",
      "defaultValue": "3.13",
      "metadata": {
        "description": "Python version for the Web App runtime"
      }
    },
    "bingApiKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Bing API key for web search tool (optional)"
      }
    }
  },
  "variables": {
    "uniqueSuffix": "[uniqueString(resourceGroup().id)]",
    "webAppName": "[format('{0}-{1}', parameters('appName'), variables('uniqueSuffix'))]",
    "appServicePlanName": "[format('{0}-plan-{1}', parameters('appName'), variables('uniqueSuffix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('skuName')]"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[format('PYTHON|{0}', parameters('pythonVersion'))]",
          "alwaysOn": true,
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "http20Enabled": true,
          "appCommandLine": "bash /home/site/wwwroot/startup.sh",
          "appSettings": [
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "false"
            },
            {
              "name": "ENABLE_ORYX_BUILD",
              "value": "false"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            },
            {
              "name": "PYTHONPATH",
              "value": "/home/site/wwwroot/.python_packages/lib/site-packages"
            },
            {
              "name": "PG_LOG_LEVEL",
              "value": "INFO"
            },
            {
              "name": "PG_BING_API_KEY",
              "value": "[parameters('bingApiKey')]"
            },
            {
              "name": "PG_UPLOAD_DIR",
              "value": "/home/uploads"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]"
      ]
    }
  ],
  "outputs": {
    "webAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "webAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2024-04-01').defaultHostName)]"
    },
    "appServicePlanName": {
      "type": "string",
      "value": "[variables('appServicePlanName')]"
    }
  }
}