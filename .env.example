# PlagiarismGuard environment variables
PG_DEBUG=true
PG_LOG_LEVEL=DEBUG

# Azure OpenAI (required for AI Rewriter feature)
PG_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
PG_AZURE_OPENAI_API_KEY=your-api-key-here
PG_AZURE_OPENAI_DEPLOYMENT=gpt-4o
PG_AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Authentication — comma-separated API keys (leave empty to disable auth in dev)
# PG_API_KEYS_RAW=pg_sk_your-key-here
