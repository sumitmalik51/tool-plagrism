{
  "openapi": "3.0.1",
  "info": {
    "title": "PlagiarismGuard",
    "description": "AI-powered multi-agent plagiarism detection system. Provides tools for text chunking, embedding generation, semantic similarity analysis, web search, AI-generated text detection, and structured report generation.",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "https://plagiarismguard-jl6yu5wij5mu4.azurewebsites.net",
      "description": "Production"
    }
  ],
  "paths": {
    "/tools/chunk": {
      "post": {
        "summary": "Split text into overlapping chunks for analysis",
        "description": "Splits a document's text into overlapping chunks using sentence-boundary-aware splitting. Use this as the first step before embedding generation or AI detection.",
        "operationId": "chunkText",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChunkRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully chunked text",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChunkResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tools/embeddings": {
      "post": {
        "summary": "Generate text embeddings",
        "description": "Generate normalized vector embeddings for a list of text strings using a sentence-transformer model. Returns L2-normalized vectors suitable for cosine similarity.",
        "operationId": "generateEmbeddings",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmbeddingsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully generated embeddings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmbeddingsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tools/similarity": {
      "post": {
        "summary": "Compute cosine similarity between text embeddings",
        "description": "Computes pairwise cosine similarity between two sets of pre-computed embeddings and identifies high-similarity pairs above a threshold. Returns an overall plagiarism score.",
        "operationId": "computeSimilarity",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SimilarityRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Similarity analysis result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SimilarityResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tools/web-search": {
      "post": {
        "summary": "Search the web for matching content",
        "description": "Search the web using Bing Search API to find potential source material that matches the provided query. Useful for checking if text passages appear elsewhere online.",
        "operationId": "webSearch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Web search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebSearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tools/ai-detect": {
      "post": {
        "summary": "Detect AI-generated text",
        "description": "Analyse text for indicators of AI-generated content using statistical heuristics including vocabulary richness, sentence length variance, and repeated n-gram detection.",
        "operationId": "aiDetect",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AIDetectRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI detection analysis result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AIDetectResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tools/generate-report": {
      "post": {
        "summary": "Generate a structured plagiarism report",
        "description": "Accepts pre-computed analysis results (similarity scores, AI detection scores, flagged passages, detected sources) and produces a structured JSON report with risk level, explanation, and flagged passages.",
        "operationId": "generateReport",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateReportRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Structured plagiarism report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlagiarismReportResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analyze-agent": {
      "post": {
        "summary": "Run full multi-agent plagiarism analysis on text",
        "description": "Accepts raw text and runs the complete multi-agent plagiarism detection pipeline (semantic analysis, web search, academic checking, AI detection) in parallel. Returns a comprehensive plagiarism report with scores, risk level, flagged passages, detected sources, and explanation.",
        "operationId": "analyzeText",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyzeTextRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Full plagiarism analysis report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlagiarismReportResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnalyzeTextRequest": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "The plain text to analyse for plagiarism. The full multi-agent pipeline will run on this text."
          }
        }
      },
      "ChunkRequest": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "The full document text to split into chunks"
          },
          "chunk_size": {
            "type": "integer",
            "minimum": 50,
            "description": "Target number of characters per chunk. Defaults to 500 if not specified."
          },
          "overlap": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of overlapping characters between consecutive chunks. Defaults to 100 if not specified."
          }
        }
      },
      "ChunkResponse": {
        "type": "object",
        "properties": {
          "chunks": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of text chunks"
          },
          "chunk_count": {
            "type": "integer",
            "description": "Total number of chunks produced"
          },
          "chunk_size": {
            "type": "integer",
            "description": "Chunk size used"
          },
          "overlap": {
            "type": "integer",
            "description": "Overlap used"
          }
        }
      },
      "EmbeddingsRequest": {
        "type": "object",
        "required": ["texts"],
        "properties": {
          "texts": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "List of text strings to generate embeddings for"
          }
        }
      },
      "EmbeddingsResponse": {
        "type": "object",
        "properties": {
          "embeddings": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "number" }
            },
            "description": "L2-normalized embedding vectors"
          },
          "model": {
            "type": "string",
            "description": "Name of the embedding model used"
          },
          "dimension": {
            "type": "integer",
            "description": "Dimensionality of each embedding vector"
          },
          "count": {
            "type": "integer",
            "description": "Number of embeddings generated"
          },
          "elapsed_s": {
            "type": "number",
            "description": "Processing time in seconds"
          }
        }
      },
      "SimilarityRequest": {
        "type": "object",
        "required": ["texts_a", "texts_b", "embeddings_a", "embeddings_b"],
        "properties": {
          "texts_a": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "First set of text chunks (document under review)"
          },
          "texts_b": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Second set of text chunks (reference material)"
          },
          "embeddings_a": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "number" }
            },
            "description": "Pre-computed embeddings for texts_a"
          },
          "embeddings_b": {
            "type": "array",
            "items": {
              "type": "array",
              "items": { "type": "number" }
            },
            "description": "Pre-computed embeddings for texts_b"
          },
          "threshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Similarity threshold (0-1). Pairs above this are flagged. Default: 0.8"
          }
        }
      },
      "SimilarityResponse": {
        "type": "object",
        "properties": {
          "score": {
            "type": "number",
            "description": "Overall plagiarism score (0-100)"
          },
          "flagged_ratio": {
            "type": "number",
            "description": "Fraction of document chunks above threshold"
          },
          "max_similarity": {
            "type": "number",
            "description": "Highest similarity found"
          },
          "mean_similarity": {
            "type": "number",
            "description": "Average similarity across all chunk pairs"
          },
          "threshold": {
            "type": "number",
            "description": "Threshold used for flagging"
          },
          "high_similarity_pairs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "chunk_a_idx": { "type": "integer", "description": "Index of chunk from texts_a" },
                "chunk_b_idx": { "type": "integer", "description": "Index of chunk from texts_b" },
                "similarity": { "type": "number", "description": "Cosine similarity score" }
              }
            },
            "description": "Pairs of chunks with similarity above threshold"
          },
          "elapsed_s": {
            "type": "number",
            "description": "Processing time in seconds"
          }
        }
      },
      "WebSearchRequest": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "description": "The search query to find matching content on the web"
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "description": "Number of search results to return. Default: 5"
          }
        }
      },
      "WebSearchResponse": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The original search query"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": { "type": "string", "description": "URL of the search result" },
                "title": { "type": "string", "description": "Title of the search result" },
                "snippet": { "type": "string", "description": "Text snippet from the result" }
              }
            },
            "description": "List of web search results"
          },
          "result_count": {
            "type": "integer",
            "description": "Number of results returned"
          },
          "elapsed_s": {
            "type": "number",
            "description": "Search time in seconds"
          }
        }
      },
      "AIDetectRequest": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "The text to analyse for AI-generated content"
          },
          "chunks": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional pre-split text chunks for per-chunk AI detection analysis"
          }
        }
      },
      "AIDetectResponse": {
        "type": "object",
        "properties": {
          "score": {
            "type": "number",
            "description": "AI detection score (0-100). Higher means more likely AI-generated."
          },
          "confidence": {
            "type": "number",
            "description": "Confidence in the detection result (0-1)"
          },
          "indicators": {
            "type": "object",
            "properties": {
              "type_token_ratio": { "type": "number", "description": "Vocabulary richness ratio" },
              "ttr_signal": { "type": "number", "description": "Type-token ratio signal strength" },
              "burstiness_signal": { "type": "number", "description": "Sentence length variance signal" },
              "repetition_signal": { "type": "number", "description": "Repeated n-gram signal" },
              "sentence_count": { "type": "integer", "description": "Number of sentences analysed" },
              "word_count": { "type": "integer", "description": "Number of words analysed" }
            },
            "description": "Individual detection indicator values"
          },
          "flagged_chunks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "chunk_index": { "type": "integer", "description": "Index of the flagged chunk" },
                "text": { "type": "string", "description": "First 200 chars of the flagged chunk" },
                "reason": { "type": "string", "description": "Why this chunk was flagged" }
              }
            },
            "description": "Chunks flagged as potentially AI-generated"
          },
          "elapsed_s": {
            "type": "number",
            "description": "Processing time in seconds"
          }
        }
      },
      "GenerateReportRequest": {
        "type": "object",
        "required": ["document_id", "plagiarism_score", "confidence_score"],
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Unique identifier for the document being analysed"
          },
          "plagiarism_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Overall plagiarism score from similarity analysis (0-100)"
          },
          "confidence_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Overall confidence in the results (0-1)"
          },
          "ai_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "AI detection score (0-100). Optional."
          },
          "flagged_passages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["text", "similarity_score"],
              "properties": {
                "text": { "type": "string", "description": "The flagged text passage" },
                "similarity_score": { "type": "number", "description": "Similarity score (0-1)" },
                "source": { "type": "string", "description": "Source URL or reference" },
                "reason": { "type": "string", "description": "Why the passage was flagged" }
              }
            },
            "description": "List of passages flagged during analysis"
          },
          "detected_sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": { "type": "string", "description": "URL of the matched source" },
                "title": { "type": "string", "description": "Title of the matched source" },
                "similarity": { "type": "number", "description": "Similarity with the source (0-1)" }
              }
            },
            "description": "Sources detected as potential origins"
          }
        }
      },
      "PlagiarismReportResponse": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Document identifier"
          },
          "plagiarism_score": {
            "type": "number",
            "description": "Overall plagiarism score (0-100)"
          },
          "confidence_score": {
            "type": "number",
            "description": "Overall confidence (0-1)"
          },
          "risk_level": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH"],
            "description": "Risk classification based on plagiarism score"
          },
          "flagged_passages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": { "type": "string", "description": "Flagged text" },
                "similarity_score": { "type": "number", "description": "Similarity score" },
                "source": { "type": "string", "description": "Source URL" },
                "reason": { "type": "string", "description": "Reason for flagging" }
              }
            },
            "description": "Passages flagged as potentially plagiarised"
          },
          "detected_sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": { "type": "string", "description": "Source URL" },
                "title": { "type": "string", "description": "Source title" },
                "similarity": { "type": "number", "description": "Similarity score" }
              }
            },
            "description": "Detected source materials"
          },
          "explanation": {
            "type": "string",
            "description": "Human-readable summary explaining the analysis results, risk level, and recommendations"
          },
          "generated_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of report generation"
          }
        }
      }
    }
  }
}